# Frontend environment example
# VITE_ variables are public in browser builds.
# Never put real secrets here.

VITE_BACKEND_URL=http://127.0.0.1:5000
VITE_SHOW_DEMO_PASSWORD=true
VITE_OWNER_DEMO_PASSWORD=
VITE_APP_MODE=development
VITE_CLOVER_STARTER_DEPOSIT_LINK=
VITE_CLOVER_STARTER_FULL_LINK=
VITE_CLOVER_PRO_DEPOSIT_LINK=
VITE_CLOVER_CUSTOM_DEPOSIT_LINK=
